# =============================================================================
# Mallard Metrics — Production Environment
# =============================================================================
# Copy this file to .env in the same directory and fill in every value.
# NEVER commit .env to version control.
# On disk, permissions must be 600:  chmod 600 deploy/.env
#
# Generate secrets quickly:
#   openssl rand -base64 48   # for MALLARD_SECRET and MALLARD_ADMIN_PASSWORD
#   openssl rand -hex 32      # for MALLARD_METRICS_TOKEN
# =============================================================================

# ── Domain ────────────────────────────────────────────────────────────────────

# The hostname Caddy will serve and request a TLS cert for.
# Can be a subdomain (analytics.example.com) or apex (example.com).
DOMAIN=analytics.example.com

# Let's Encrypt registration email — receives cert expiry warnings.
ACME_EMAIL=admin@example.com

# ── Cloudflare DNS challenge ───────────────────────────────────────────────────

# Cloudflare API token used by Caddy to complete the DNS-01 ACME challenge.
# Required scopes (create at dash.cloudflare.com → My Profile → API Tokens):
#   Zone → Zone → Read
#   Zone → DNS  → Edit
# Restrict the token to the specific zone that DOMAIN belongs to.
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# ── Mallard secrets (REQUIRED — change every value) ───────────────────────────

# 48+ byte random secret for HMAC visitor ID hashing.
# Changing this re-fingerprints ALL visitors (use a stable value in production).
MALLARD_SECRET=CHANGE_ME_run_openssl_rand_-base64_48

# Dashboard admin password (bcrypt-hashed at login; leave blank to disable auth).
# Recommended: 20+ characters, mix of upper/lower/digit/symbol.
MALLARD_ADMIN_PASSWORD=CHANGE_ME_strong_passphrase_here

# Bearer token required to scrape GET /metrics (Prometheus endpoint).
# Leave blank to expose metrics without authentication (not recommended).
MALLARD_METRICS_TOKEN=CHANGE_ME_run_openssl_rand_-hex_32

# ── Host data directory ───────────────────────────────────────────────────────

# Absolute path on the HOST where DuckDB + Parquet files are stored.
# setup.sh mounts a LUKS-encrypted container here before starting Docker.
# Do NOT change this after first deployment without migrating data.
MALLARD_DATA_HOST_DIR=/srv/mallard/data

# ── Behaviour ─────────────────────────────────────────────────────────────────

# Retention: delete Parquet partitions older than N days (0 = keep forever).
MALLARD_RETENTION_DAYS=365

# Rate limiting: max ingest events per second per site_id (0 = unlimited).
MALLARD_RATE_LIMIT_PER_SITE=200

# Query result cache TTL in seconds (0 = disabled).
MALLARD_CACHE_TTL_SECS=300

# Concurrent analytics query cap (prevents DuckDB overload under heavy load).
MALLARD_MAX_CONCURRENT_QUERIES=10

# Brute-force protection: lock out an IP after N failed login attempts.
MALLARD_MAX_LOGIN_ATTEMPTS=5

# Lockout duration in seconds after max failed attempts.
MALLARD_LOGIN_LOCKOUT=300

# ── Optional: GeoIP ───────────────────────────────────────────────────────────

# Absolute path to a MaxMind GeoLite2-City.mmdb file inside the container.
# The file must be placed in MALLARD_DATA_HOST_DIR on the host, then:
#   MALLARD_GEOIP_DB_PATH=/data/GeoLite2-City.mmdb
# Leave blank to disable country/region/city resolution.
# MALLARD_GEOIP_DB_PATH=

# ── Optional: Site allowlist ──────────────────────────────────────────────────

# Comma-separated list of site_ids that are allowed to send events.
# Empty (default) allows events from any domain.
# Example: MALLARD_SITE_IDS=example.com,blog.example.com
# MALLARD_SITE_IDS=
